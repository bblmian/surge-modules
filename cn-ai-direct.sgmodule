; 智谱 AI / ChatGLM
DOMAIN-SUFFIX,bigmodel.cn,DIRECT

; 月之暗面 Kimi（moonshot.ai 为境外端点，不加）
DOMAIN-SUFFIX,moonshot.cn,DIRECT

; MiniMax（minimax.io 为境外端点，不加）
DOMAIN-SUFFIX,minimaxi.com,DIRECT
DOMAIN-SUFFIX,minimaxi.chat,DIRECT

; 百川智能
